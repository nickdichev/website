---
import { SITE_NAME } from "../consts";
import ToggleTheme from "./ToggleTheme.astro";
import ToggleLavaLamp from "./ToggleLavaLamp.astro";
---

<div
  id="site-header"
  class="container mx-auto md:max-w-4xl xl:max-w-7xl p-4 fixed top-0 left-0 right-0 z-50 flex justify-between items-center transition-[backdrop-filter,background-color] duration-300"
>
  <a class="text-3xl text-brand font-righteous" href="/">{SITE_NAME}</a>
  <div class="flex items-center gap-1">
    <ToggleLavaLamp />
    <ToggleTheme />
  </div>
</div>

<script>
  const header = document.getElementById("site-header")!;

  function updateHeader() {
    if (window.scrollY > 0) {
      header.classList.add("backdrop-blur-md", "bg-background/80");
    } else {
      header.classList.remove("backdrop-blur-md", "bg-background/80");
    }
  }

  updateHeader();
  window.addEventListener("scroll", updateHeader, { passive: true });
</script>
